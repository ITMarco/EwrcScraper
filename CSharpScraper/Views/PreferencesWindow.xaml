<Window x:Class="EwrcScraper.Views.PreferencesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Voorkeuren — EWRC Scraper"
        Height="600" Width="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{StaticResource LightBgBrush}">
    <DockPanel>

        <Border DockPanel.Dock="Top" Background="{StaticResource PrimaryBrush}" Padding="20,14">
            <DockPanel>
                <TextBlock Text="Voorkeuren" FontSize="16" FontWeight="Bold" Foreground="White"/>
                <TextBlock DockPanel.Dock="Right" VerticalAlignment="Bottom"
                           FontSize="11" Foreground="#8AAAC8"
                           Text="{Binding HuidigeVersie, StringFormat='v{0}'}"/>
            </DockPanel>
        </Border>

        <Border DockPanel.Dock="Bottom" Background="White"
                BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="0,1,0,0"
                Padding="16,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Annuleren" Style="{StaticResource SecondaryButton}"
                        Padding="12,7" Margin="0,0,8,0" Click="Annuleer_Click"/>
                <Button Content="💾 Opslaan" Style="{StaticResource PrimaryButton}"
                        Padding="12,7" Click="Opslaan_Click"/>
            </StackPanel>
        </Border>

        <StackPanel Margin="20,16,20,0">

            <!-- Ledenlijst -->
            <TextBlock Text="Ledenlijst" FontSize="12" FontWeight="SemiBold"
                       Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,8"/>
            <TextBlock Text="Bestandslocatie (.xlsx of .csv):" FontSize="11" Foreground="#556" Margin="0,0,0,4"/>
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="📂 Bladeren..." Padding="10,5" Margin="6,0,0,0"
                        Style="{StaticResource SecondaryButton}" Click="Bladeren_Click"/>
                <TextBox x:Name="LedenlijstPadBox"
                         Text="{Binding LedenlijstPad, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Padding="8,5" BorderBrush="{StaticResource AppBorderBrush}"
                         FontFamily="Consolas" FontSize="11" IsReadOnly="False"/>
            </DockPanel>
            <TextBlock FontSize="10" Foreground="#778" Margin="0,5,0,0" FontStyle="Italic"
                       Text="Dit bestand wordt standaard geladen bij het openen van stap 2."/>

            <Separator Margin="0,14,0,14" Background="{StaticResource AppBorderBrush}"/>

            <!-- Updates -->
            <TextBlock Text="Updates" FontSize="12" FontWeight="SemiBold"
                       Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,8"/>
            <CheckBox IsChecked="{Binding ControleerUpdates, Mode=TwoWay}" Margin="2,0,0,6"
                      Content="Controleer automatisch op updates bij opstarten"/>

            <DockPanel Margin="0,4,0,0">
                <Button DockPanel.Dock="Right" Content="🔍 Controleer nu"
                        Style="{StaticResource SecondaryButton}" Padding="10,5"
                        IsEnabled="{Binding IsUpdateAanHetControleren, Converter={StaticResource InvBool}}"
                        Click="CheckNu_Click"/>
                <TextBlock Text="{Binding UpdateStatusTekst}" FontSize="11" Foreground="#556"
                           VerticalAlignment="Center" Margin="0,0,8,0" TextWrapping="Wrap"/>
            </DockPanel>

            <Separator Margin="0,14,0,14" Background="{StaticResource AppBorderBrush}"/>

            <!-- Debug -->
            <TextBlock Text="Debug" FontSize="12" FontWeight="SemiBold"
                       Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,8"/>
            <CheckBox IsChecked="{Binding DebugVensterBijOpstarten, Mode=TwoWay}" Margin="2,0,0,4"
                      Content="Debug venster automatisch openen bij opstarten"/>

            <Separator Margin="0,14,0,14" Background="{StaticResource AppBorderBrush}"/>

            <!-- Geavanceerd -->
            <TextBlock Text="Geavanceerd" FontSize="12" FontWeight="SemiBold"
                       Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,8"/>
            <TextBlock Text="API basis URL:" FontSize="11" Foreground="#556" Margin="0,0,0,4"/>
            <TextBox Text="{Binding ApiBaseUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Padding="8,5" BorderBrush="{StaticResource AppBorderBrush}"
                     FontFamily="Consolas" FontSize="11"/>
            <TextBlock FontSize="10" Foreground="#778" Margin="0,5,0,0" FontStyle="Italic"
                       Text="Wijzig alleen als eWRC een nieuw API-adres gebruikt. Herstart vereist."/>

        </StackPanel>
    </DockPanel>
</Window>
